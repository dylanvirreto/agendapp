{
  "expo": {
    "name": "Mi Agenda",
    "slug": "mi-agenda-personal",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "primaryColor": "#7A213A",
    "backgroundColor": "#F5E4E7",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tuusuario.miagenda",
      "statusBarStyle": "light-content"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#7A213A"
      },
      "package": "com.tuusuario.miagenda",
      "statusBar": {
        "backgroundColor": "#7A213A",
        "barStyle": "light-content"
      },
      "permissions": [
        "NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "backgroundColor": "#F5E4E7"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#7A213A"
        }
      ]
    ]
  }
}
